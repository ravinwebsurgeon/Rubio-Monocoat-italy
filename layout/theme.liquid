    <script>
$(document).ready(function () {
  function initFooterAccordion() {
    if ($(window).width() < 990) {
      // hide by default
      $(".footer-block__details-content").hide();

      $(".footer-block__heading").off("click").on("click", function () {
        let content = $(this).next(".footer-block__details-content");

        // close others
        $(".footer-block__details-content").not(content).slideUp();
        $(".footer-block__heading").not(this).removeClass("active");

        // toggle clicked one
        $(this).toggleClass("active");
        content.slideToggle();
      });
    } else {
      // reset for desktop
      $(".footer-block__details-content").show();
      $(".footer-block__heading").off("click").removeClass("active");
    }
  }

  // run on page load
  initFooterAccordion();

  // run on resize
  $(window).resize(function () {
    initFooterAccordion();
  });
});


