function renderWishlistPage() {
  const wishlistData = JSON.parse(localStorage.getItem('wishlist')) || [];
  const container = document.querySelector('.js-wishlistBlock');
  if (!container) return;

  if (wishlistData.length === 0) {
    container.innerHTML = '<p>Your wishlist is empty.</p>';
    return;
  }

  container.innerHTML = '';
  wishlistData.forEach(item => {
    const productHTML = `
      <div class="wishlist-item" style="margin-bottom: 30px;">
        <a href="${item.productUrl}">
          <img loading="lazy" class="check-l" src="${item.productImg}" alt="${item.productTitle} ">
        </a>
        <h4><a class="wish-tit" href="${item.productUrl}">${item.productTitle}</a></h4>
        <p class="price-wish">${item.productPrice}</p>
      <button class="remove-btn" onclick="removeFromWishlist('${item.productId}')">Remove</button>

      </div>
    `;
    container.innerHTML += productHTML;
  });
}

function removeFromWishlist(productId) {
  let wishlistData = JSON.parse(localStorage.getItem('wishlist')) || [];
  wishlistData = wishlistData.filter(item => item.productId !== productId);
  localStorage.setItem('wishlist', JSON.stringify(wishlistData));
  renderWishlistPage();
}


   

document.addEventListener('DOMContentLoaded', function () {
  // Highlight buttons if present
  const wishlistData = JSON.parse(localStorage.getItem('wishlist')) || [];
  document.querySelectorAll('.wishlist_button').forEach(button => {
    const pid = button.dataset.id;
    const isInWishlist = wishlistData.some(item => item.productId === pid);
    button.innerHTML = isInWishlist ? getFilledHeartSVG() : getOutlinedHeartSVG();
  });

  // Render wishlist if this is the wishlist page
  renderWishlistPage();
});
