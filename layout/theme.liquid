    <script>
function toggleWishlist(button) {
  const productData = {
    productId: button.dataset.id,
    productTitle: button.dataset.title,
    productImg: button.dataset.image ,
    productPrice: button.dataset.price,
    productUrl: button.dataset.url
  };

  let wishlistData = JSON.parse(localStorage.getItem('wishlist')) || [];
  const index = wishlistData.findIndex(item => item.productId === productData.productId);

  if (index === -1) {
    wishlistData.push(productData);
    button.innerHTML = getFilledHeartSVG();
  } else {
    wishlistData.splice(index, 1);
    button.innerHTML = getOutlinedHeartSVG();
  }

  localStorage.setItem('wishlist', JSON.stringify(wishlistData));
  renderWishlistPage(); // Optional: re-render wishlist after toggle
}

